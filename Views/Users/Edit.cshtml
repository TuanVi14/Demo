@model Demo.Models.User

@{
    ViewData["Title"] = "Edit User";
}

<h2>Edit User</h2>

<form method="post">
    <input type="hidden" name="id" value="@Model.Id" />
    <div class="form-group">
        <label>Username</label>
        <input class="form-control" value="@Model.Username" disabled />
    </div>
    <div class="form-group">
        <label>New Password (leave blank to keep)</label>
        <input class="form-control" type="password" name="password" />
    </div>
    <div class="form-group">
        <label>Roles</label>
        <div>
            @{ var roles = (Model.Roles ?? "").Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries); }
            <label class="me-2"><input type="checkbox" name="roles" value="Admin" @(roles.Contains("Admin")?"checked":"") /> Admin</label>
            <label class="me-2"><input type="checkbox" name="roles" value="User" @(roles.Contains("User")?"checked":"") /> User</label>
            <label class="me-2"><input type="checkbox" name="roles" value="Manager" @(roles.Contains("Manager")?"checked":"") /> Manager</label>
        </div>
    </div>
    <div class="form-group">
        <label>Address</label>
        <input class="form-control" name="address" value="@Model.Address" />
    </div>
    <div class="form-group">
        <label>Customer Group</label>
        <select class="form-control" name="customerGroup">
            @{ var grp = Model.CustomerGroup ?? "Regular"; }
            @if (grp == "Regular") { <option value="Regular" selected>Regular</option> } else { <option value="Regular">Regular</option> }
            @if (grp == "VIP") { <option value="VIP" selected>VIP</option> } else { <option value="VIP">VIP</option> }
            @if (grp == "Wholesale") { <option value="Wholesale" selected>Wholesale</option> } else { <option value="Wholesale">Wholesale</option> }
        </select>
    </div>
    <button class="btn btn-primary" type="submit">Save</button>
    <a class="btn btn-secondary" href="/Users">Back</a>
</form>

@if (Model.Addresses?.Any() == true)
{
    <h3 class="mt-4">Customer Addresses</h3>
    <p><a class="btn btn-sm btn-primary" href="/CustomerAddresses/Create?userId=@Model.Id">Add Address</a></p>
    <table class="table">
        <thead>
            <tr>
                <th>Id</th>
                <th>Address</th>
                <th>City</th>
                <th>State</th>
                <th>Postal Code</th>
                <th>Country</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
        @foreach (var address in Model.Addresses)
        {
            <tr>
                <td>@address.Id</td>
                <td>@address.AddressLine</td>
                <td>@address.City</td>
                <td>@address.State</td>
                <td>@address.PostalCode</td>
                <td>@address.Country</td>
                <td>
                    <a class="btn btn-sm btn-secondary" href="/CustomerAddresses/Edit/@address.Id">Edit</a>
                    <form asp-action="Delete" method="post" style="display:inline">
                        <input type="hidden" name="id" value="@address.Id" />
                        <button class="btn btn-sm btn-danger" type="submit">Delete</button>
                    </form>
                </td>
            </tr>
        }
        </tbody>
    </table>
}
else
{
    <div class="mt-4">
        <a class="btn btn-sm btn-primary" href="/CustomerAddresses/Create?userId=@Model.Id">Add Address for this customer</a>
    </div>
}
